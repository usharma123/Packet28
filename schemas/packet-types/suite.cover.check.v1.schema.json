{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "suite.cover.check.v1.schema.json",
  "title": "Packet Type Contract: suite.cover.check.v1",
  "type": "object",
  "required": ["schema_version", "packet_type", "packet"],
  "properties": {
    "schema_version": {
      "const": "suite.packet.v1"
    },
    "packet_type": {
      "const": "suite.cover.check.v1"
    },
    "packet": {
      "type": "object",
      "required": ["version", "tool", "kind", "hash", "summary", "budget_cost", "provenance", "payload"],
      "properties": {
        "payload": {
          "type": "object",
          "required": ["passed","violations"],
          "properties": {
            "debug": {},
            "truncated": {},
            "returned_count": {},
            "total_count": {},
            "artifact_handle": {}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "x-required_payload_fields": ["passed","violations"],
  "x-optional_payload_fields": ["issue_counts","debug","truncated","artifact_handle"],
  "x-boundedness_rules": ["gate summary only","bounded issue counts"],
  "x-compatibility_notes": ["legacy envelope_v1/gate_result shim supported for one release"]
}
