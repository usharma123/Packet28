      "properties": {
        "payload": {
          "type": "object",
          "required": ["task_id", "event_id", "occurred_at_unix", "actor", "kind", "data"],
          "properties": {
            "paths": {},
            "symbols": {},
            "debug": {},
            "artifact_handle": {}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "x-required_payload_fields": ["task_id", "event_id", "occurred_at_unix", "actor", "kind", "data"],
  "x-optional_payload_fields": ["paths", "symbols", "debug", "artifact_handle"],
  "x-boundedness_rules": ["single event payload", "bounded path and symbol refs"],
  "x-compatibility_notes": ["v1 task-state event contract"]
}
