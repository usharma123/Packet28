{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "suite.agent.state.v1.schema.json",
  "title": "Packet Type Contract: suite.agent.state.v1",
  "type": "object",
  "required": ["schema_version", "packet_type", "packet"],
  "properties": {
    "schema_version": {
      "const": "suite.packet.v1"
    },
    "packet_type": {
      "const": "suite.agent.state.v1"
    },
    "packet": {
