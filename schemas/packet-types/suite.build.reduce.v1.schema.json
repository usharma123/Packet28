{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "suite.build.reduce.v1.schema.json",
  "title": "Packet Type Contract: suite.build.reduce.v1",
  "type": "object",
  "required": ["schema_version", "packet_type", "packet"],
  "properties": {
    "schema_version": {
      "const": "suite.packet.v1"
    },
    "packet_type": {
      "const": "suite.build.reduce.v1"
    },
    "packet": {
      "type": "object",
      "required": ["version", "tool", "kind", "hash", "summary", "budget_cost", "provenance", "payload"],
      "properties": {
        "payload": {
          "type": "object",
          "required": ["unique_diagnostics","total_diagnostics"],
          "properties": {
            "debug": {},
            "truncated": {},
            "returned_count": {},
            "total_count": {},
            "artifact_handle": {}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "x-required_payload_fields": ["unique_diagnostics","total_diagnostics"],
  "x-optional_payload_fields": ["groups","ordered_fixes","debug","truncated","returned_count","total_count","artifact_handle"],
  "x-boundedness_rules": ["diagnostic groups truncated in compact profile"],
  "x-compatibility_notes": ["legacy build packet shape supported for one release"]
}
