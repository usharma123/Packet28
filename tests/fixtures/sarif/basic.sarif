{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "eslint",
          "rules": [
            { "id": "no-unused-vars" },
            { "id": "eqeqeq" },
            { "id": "no-console" }
          ]
        }
      },
      "results": [
        {
          "ruleId": "no-unused-vars",
          "level": "error",
          "message": { "text": "x is assigned a value but never used." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/main.rs" },
                "region": { "startLine": 10, "startColumn": 5 }
              }
            }
          ],
          "fingerprints": {
            "primaryLocationLineHash": "eslint-fp-1"
          }
        },
        {
          "ruleIndex": 1,
          "level": "warning",
          "message": { "text": "Expected '===' and instead saw '=='." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/main.rs" },
                "region": { "startLine": 20 }
              }
            }
          ],
          "partialFingerprints": {
            "primaryLocationStartColumnFingerprint": "eslint-partial-1"
          }
        },
        {
          "ruleId": "no-console",
          "level": "note",
          "message": { "text": "Unexpected console statement." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/lib.rs" },
                "region": { "startLine": 5 }
              }
            }
          ]
        },
        {
          "ruleId": "missing-location",
          "level": "error",
          "message": { "text": "This should be skipped" }
        }
      ]
    },
    {
      "tool": {
        "driver": {
          "name": "codeql",
          "rules": [
            { "id": "rust/unreachable-code" }
          ]
        }
      },
      "results": [
        {
          "ruleId": "rust/unreachable-code",
          "level": "error",
          "message": { "text": "This code is unreachable." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/lib.rs" },
                "region": { "startLine": 40 }
              }
            }
          ],
          "fingerprints": {
            "location": "codeql-fp-1"
          }
        },
        {
          "ruleIndex": 0,
          "level": "warning",
          "message": { "text": "Potential unreachable condition." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/lib.rs" },
                "region": { "startLine": 41 }
              }
            }
          ],
          "partialFingerprints": {
            "foo": "codeql-partial-2"
          }
        },
        {
          "ruleId": "rust/unreachable-code",
          "level": "error",
          "message": { "text": "Duplicate fingerprint should be deduped." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/lib.rs" },
                "region": { "startLine": 42 }
              }
            }
          ],
          "fingerprints": {
            "location": "codeql-fp-1"
          }
        }
      ]
    }
  ]
}
